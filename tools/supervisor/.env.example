# Pianoid Supervisor — example environment (Phase 1)
#
# Copy to `.env` (gitignored) ONLY if you need the --live path. The default
# (no --live) uses the loopback transport and needs NO token.
#
# ⚠️ NEVER put the live orchestrator's production TELEGRAM_BOT_TOKEN here.
# The supervisor's live poller uses a DEDICATED/TEST token, so it can never
# collide (409) with the running orchestrator's own poller.

# A DEDICATED Telegram bot token (NOT the production one) for `--live`.
# SUPERVISOR_TELEGRAM_TOKEN=123456789:AA-dedicated-test-token

# Optional: override the supervisor state dir (queue + capture + logs live here).
# Defaults to ~/.claude/supervisor — separate from the live plugin's state dir.
# SUPERVISOR_STATE_DIR=
