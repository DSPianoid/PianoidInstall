# Default: treat all files as text, store with LF in the repo
* text=auto eol=lf

# Windows-only scripts — keep CRLF on every checkout
# (cmd.exe and some PowerShell hosts misbehave on LF-only files)
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Lock common text formats to LF explicitly
*.svg   text eol=lf

# Binary files — never EOL-convert, never line-end-normalize
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.7z    binary
*.tar   binary
*.gz    binary
*.exe   binary
*.dll   binary
*.pyd   binary
*.so    binary
*.wav   binary
*.mp3   binary
*.ogg   binary
*.mp4   binary
